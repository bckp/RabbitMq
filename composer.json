{
	"name": "bckp/rabbitmq",
	"type": "library",
	"description": "Integrates php-amqplib with RabbitMq and Nette Framework",
	"keywords": ["nette", "kdyby", "rabbitmq", "rabbit", "bunny", "amqp", "messaging", "message", "queue"],
	"homepage": "http://kdyby.org",
	"license": ["MIT"],
	"authors": [
		{
			"name": "Alvaro Videla"
		},
		{
			"name": "Filip Procházka",
			"homepage": "http://filip-prochazka.com",
			"email": "filip@prochazka.su"
		},
		{
			"name": "Radovan Kepák",
			"homepage": "https://kepak.eu"
		}
	],
	"require": {
		"php": ">=7.1",
		"nette/di": ">=2.4.17",
		"nette/utils": ">=2.5.7 <4",
		"php-amqplib/php-amqplib": "~2.12.3"
	},
	"require-dev": {
		"nette/caching": ">=2.5",
		"nette/bootstrap": ">=2.4",
		"nette/http": ">=2.4",
		"tracy/tracy": ">=2.5",
		"nette/tester": "^2.4",
		"mockery/mockery": "^1.3",
		"kdyby/console": "^2.7",
		"symfony/console": ">=3"
	},
	"support": {
		"email": "filip@prochazka.su",
		"issues": "https://github.com/Kdyby/RabbitMq/issues"
	},
	"autoload": {
		"psr-0": {
			"Kdyby\\RabbitMq\\": "src/"
		},
		"classmap": [
			"src/Kdyby/RabbitMq/exceptions.php"
		]
	},
	"extra": {
		"branch-alias": {
			"dev-master": "1.3-dev"
		}
	},
	"replace": {
		"kdyby/rabbitmq": "1.2.*"
	}
}
